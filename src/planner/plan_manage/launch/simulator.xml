    <!-- ======================= 简化位置命令转换器(当前使用) ======================= -->
    <!-- 将位置命令直接转换为里程计信息，跳过复杂的动力学仿真 -->
    <node pkg="poscmd_2_odom" name="drone_$(arg drone_id)_poscmd_2_odom" type="poscmd_2_odom" output="screen">
        <!-- 初始位置设置 -->
        <param name="init_x" value="$(arg init_x_)"/>               <!-- 起始X坐标 -->
        <param name="init_y" value="$(arg init_y_)"/>               <!-- 起始Y坐标 -->
        <param name="init_z" value="$(arg init_z_)"/>               <!-- 起始Z坐标 -->
        
        <!-- 话题连接 -->
        <remap from="~command" to="drone_$(arg drone_id)_planning/pos_cmd"/>           <!-- 接收规划器位置命令 -->
        <remap from="~odometry" to="drone_$(arg drone_id)_$(arg odometry_topic)"/>     <!-- 输出里程计信息 -->
    </node>

    <!-- ======================= 可视化模块 ======================= -->
    <!-- 在RViz中显示无人机位姿、轨迹和状态 -->
    <node pkg="odom_visualization" name="drone_$(arg drone_id)_odom_visualization" type="odom_visualization" output="screen">
        <!-- 数据源 -->
        <remap from="~odom" to="drone_$(arg drone_id)_visual_slam/odom"/>              <!-- 里程计数据输入 -->
        
        <!-- 可视化颜色设置(RGBA) -->
        <param name="color/a" value="1.0"/>                         <!-- 透明度: 100%(完全不透明) -->
        <param name="color/r" value="0.0"/>                         <!-- 红色分量: 0 -->
        <param name="color/g" value="0.0"/>                         <!-- 绿色分量: 0 -->
        <param name="color/b" value="0.0"/>                         <!-- 蓝色分量: 0 -> 结果=黑色 -->
        
        <!-- 显示参数 -->
        <param name="covariance_scale" value="100.0"/>              <!-- 位置不确定性显示缩放 -->
        <param name="robot_scale" value="0.35"/>                    <!-- 无人机模型显示大小: 35% -->
        <param name="tf45" value="false"/>                          <!-- 不使用45度坐标转换 -->
        <param name="drone_id" value="drone_id"/>                   <!-- 显示的无人机标识 -->
    </node>

    <!-- ======================= 局部感知模块 ======================= -->
    <!-- 模拟深度相机，生成局部环境的点云数据 -->
    <node pkg="local_sensing_node" type="pcl_render_node" name="drone_$(arg drone_id)_pcl_render_node" output="screen">
        <!-- 相机内参配置 -->
        <rosparam command="load" file="$(find local_sensing_node)/params/camera.yaml" />
        
        <!-- 感知能力参数 -->
        <param name="sensing_horizon"  value="5.0" />               <!-- 最大感知距离: 5米 -->
        <param name="sensing_rate"     value="30.0"/>               <!-- 感知数据更新频率: 30Hz -->
        <param name="estimation_rate"  value="30.0"/>               <!-- 状态估计频率: 30Hz -->
        
        <!-- 地图范围(与全局地图一致) -->
        <param name="map/x_size"     value="$(arg map_size_x_)"/>   <!-- 感知区域X轴范围 -->
        <param name="map/y_size"     value="$(arg map_size_y_)"/>   <!-- 感知区域Y轴范围 -->
        <param name="map/z_size"     value="$(arg map_size_z_)"/>   <!-- 感知区域Z轴范围 -->
        
        <!-- 话题连接 -->
        <remap from="~global_map" to="/map_generator/global_cloud"/>                    <!-- 全局地图输入 -->
        <remap from="~odometry"   to="/drone_$(arg drone_id)_$(arg odometry_topic)"/>  <!-- 位置信息输入 -->
        <remap from="~pcl_render_node/cloud"   to="/drone_$(arg drone_id)_pcl_render_node/cloud"/>  <!-- 局部点云输出 -->
    </node>
</launch>

<!-- 
======================= 系统工作流程总结 =======================

单架无人机仿真系统的数据流:
1. 【规划器】生成位置命令 → /drone_X_planning/pos_cmd
2. 【位置转换器】接收命令 → 直接转为里程计数据 → /drone_X_visual_slam/odom
3. 【感知系统】根据位置 → 提取5米范围内点云 → /drone_X_pcl_render_node/cloud
4. 【可视化】显示轨迹和状态 → RViz界面

当前配置特点:
✓ 使用简化动力学(快速仿真,不考虑真实物理)
✓ 30Hz高频感知更新(适合快速飞行)
✓ 5米感知半径(适合密集障碍物环境)
✓ 支持多机并行仿真(通过drone_id区分)
✗ 未启用地图生成器(地图由formation.launch中的全局生成器提供)
✗ 未启用真实四旋翼动力学(为了提高仿真效率)
-->