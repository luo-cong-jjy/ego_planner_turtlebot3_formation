<launch>
    <!-- ======================= 输入参数定义 ======================= -->
    <!-- 这些参数由上层launch文件(如run_in_sim.launch)传入 -->
    
    <!-- 无人机初始位置坐标 -->
    <arg name="init_x_"/>      <!-- 初始X坐标(米) -->
    <arg name="init_y_"/>      <!-- 初始Y坐标(米) -->
    <arg name="init_z_"/>      <!-- 初始Z坐标(高度,米) -->
    
    <!-- 动态障碍物配置 -->
    <arg name="obj_num" value="1" />    <!-- 动态障碍物数量(暂未使用) -->
    
    <!-- 仿真环境尺寸 -->
    <arg name="map_size_x_"/>   <!-- 地图X轴范围(米) -->
    <arg name="map_size_y_"/>   <!-- 地图Y轴范围(米) -->
    <arg name="map_size_z_"/>   <!-- 地图Z轴高度(米) -->
    
    <!-- 障碍物生成参数 -->
    <arg name="c_num"/>         <!-- 圆形障碍物数量 -->
    <arg name="p_num"/>         <!-- 多边形障碍物数量 -->
    <arg name="min_dist"/>      <!-- 障碍物间最小安全距离(米) -->
    
    <!-- ROS通信配置 -->
    <arg name="odometry_topic"/>    <!-- 里程计话题名称 -->
    <arg name="drone_id"/>          <!-- 无人机唯一标识符(0-6) -->

    <!-- ======================= 地图生成器选择 ======================= -->
    <!-- 注意: 以下两种地图生成器二选一，用CDATA注释掉不需要的 -->
    
    <!-- 【选项1】随机森林地图生成器 (当前被注释掉，不会运行) -->
    <![CDATA[node pkg ="map_generator" name ="random_forest" type ="random_forest" output = "screen">    
        <!-- 里程计话题映射 -->
        <remap from="~odometry"   to="$(arg odometry_topic)"/>    
        
        <!-- 地图物理尺寸设置 -->
        <param name="map/x_size"     value="$(arg map_size_x_)" />    <!-- 地图长度 -->
        <param name="map/y_size"     value="$(arg map_size_y_)" />    <!-- 地图宽度 -->
        <param name="map/z_size"     value="$(arg map_size_z_)" />    <!-- 地图高度 -->
        <param name="map/resolution" value="0.1"/>                   <!-- 网格分辨率: 0.1米/格 -->        

        <!-- 随机生成控制 -->
        <param name="ObstacleShape/seed" value="1"/>                 <!-- 随机种子(固定为1,保证可重复) -->
        <param name="map/obs_num"    value="$(arg p_num)"/>          <!-- 障碍物总数 -->
        
        <!-- 圆柱形障碍物尺寸范围 -->
        <param name="ObstacleShape/lower_rad" value="0.5"/>          <!-- 最小半径: 0.5米 -->
        <param name="ObstacleShape/upper_rad" value="0.7"/>          <!-- 最大半径: 0.7米 -->
        <param name="ObstacleShape/lower_hei" value="0.0"/>          <!-- 最小高度: 地面 -->
        <param name="ObstacleShape/upper_hei" value="3.0"/>          <!-- 最大高度: 3米 -->        

        <!-- 圆形障碍物参数(备用配置) -->
        <param name="map/circle_num" value="$(arg c_num)"/>          <!-- 圆形障碍物数量 -->        
        <param name="ObstacleShape/radius_l" value="0.7"/>           <!-- 半径下限 -->        
        <param name="ObstacleShape/radius_h" value="0.5"/>           <!-- 半径上限 -->        
        <param name="ObstacleShape/z_l" value="0.7"/>                <!-- 高度下限 -->        
        <param name="ObstacleShape/z_h" value="0.8"/>                <!-- 高度上限 -->        
        <param name="ObstacleShape/theta" value="0.5"/>              <!-- 角度参数 -->        

        <!-- 感知模拟参数 -->
        <param name="sensing/radius" value="5.0"/>                   <!-- 感知半径: 5米 -->        
        <param name="sensing/rate"   value="10.0"/>                  <!-- 感知更新频率: 10Hz -->  
        
        <!-- 安全约束 -->
        <param name="min_distance" value="$(arg min_dist)"/>         <!-- 障碍物间最小间距 -->         
    </node]]>
    
    <!-- 【选项2】Perlin噪声地图生成器 (当前也被注释掉，不会运行) -->
    <![CDATA[node pkg="mockamap" type="mockamap_node" name="mockamap_node" output="screen">  
        <!-- 话题映射: 将生成的地图发布到全局地图话题 -->
        <remap from="/mock_map" to="/map_generator/global_cloud"/>

        <!-- 基础参数 -->
        <param name="seed" type="int" value="127"/>                  <!-- 随机种子 -->
        <param name="update_freq" type="double" value="0.5"/>        <!-- 地图更新频率: 0.5Hz -->

        <!-- 网格分辨率 -->
        <param name="resolution" type="double" value="0.1"/>         <!-- 网格大小: 0.1米 -->

        <!-- 地图物理尺寸 -->
        <param name="x_length" value="$(arg map_size_x_)"/>          <!-- X轴长度 -->
        <param name="y_length" value="$(arg map_size_y_)"/>          <!-- Y轴长度 -->
        <param name="z_length" value="$(arg map_size_z_)"/>          <!-- Z轴高度 -->

        <!-- Perlin噪声地形生成参数 -->
        <param name="type" type="int" value="1"/>                    <!-- 地图类型: 1=Perlin噪声 -->
        
        <!-- Perlin噪声控制参数 -->
        <!-- complexity: 基础噪声频率，值越大地形越复杂，典型范围0.0-0.5 -->
        <param name="complexity"    type="double" value="0.05"/>     
        <!-- fill: 障碍物填充百分比，典型范围0.0-0.4 -->
        <param name="fill"          type="double" value="0.12"/>     
        <!-- fractal: 分形层数，值越大细节越多 -->
        <param name="fractal"       type="int"    value="1"/>        
        <!-- attenuation: 分形衰减系数，典型范围0.0-0.5 -->
        <param name="attenuation"   type="double" value="0.1"/>      
    </node]]>

    <!-- ======================= 无人机动力学仿真(完整版-被注释) ======================= -->
    <!-- 以下是完整的四旋翼动力学仿真+控制器，当前被注释掉以提高计算效率 -->
